# ================================================================
# Artrese' — Environment Variables
# Copy this file to .env.local and fill in all values.
# NEVER commit .env.local to version control.
# ================================================================


# ----------------------------------------------------------------
# SUPABASE
# Found in: Supabase Dashboard > Project Settings > API
# ----------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — server-side only, NEVER expose to the browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here


# ----------------------------------------------------------------
# GMAIL (Nodemailer SMTP)
# 1. Enable 2-Step Verification on the Gmail account.
# 2. Go to myaccount.google.com/apppasswords
# 3. Create an App Password (select "Mail" as the app).
# ----------------------------------------------------------------
GMAIL_USER=yourstore@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# The email address that receives new order notifications
# Defaults to GMAIL_USER if not set
ADMIN_NOTIFICATION_EMAIL=yourstore@gmail.com


# ----------------------------------------------------------------
# CLOUDINARY
# Found in: Cloudinary Dashboard > Settings > Upload > Upload Presets
# Create an "Unsigned" upload preset for client-side uploads.
# ----------------------------------------------------------------
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=your-unsigned-preset-name


# ----------------------------------------------------------------
# APP
# Used in email links (e.g., "Open Admin Dashboard" button)
# ----------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
